# Spartan Configuration — Ornith 1.0 (local Ollama)
# Copy this file to .env if you want to customize settings

# =============================================================================
# Ornith 1.0 / Ollama Configuration
# =============================================================================
# Spartan connects to a local Ollama instance running the Ornith 1.0 model.
# No API keys are required.

# Ollama model tag (default: ornith:1.0)
LLM_MODEL=ornith:1.0

# Ollama API base URL (default: http://localhost:11434/v1)
# Override if Ollama is running on a different host or port.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Telemetry (optional)
# =============================================================================
# LANGFUSE_ENABLED=false
